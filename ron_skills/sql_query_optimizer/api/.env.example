# SQL Query Optimizer API - Environment Variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Which Claude model to use (default: claude-sonnet-4-5-20250514)
OPTIMIZER_MODEL=claude-sonnet-4-5-20250514

# Optional: Where to store credit data (default: ./data)
DATA_DIR=./data

# Optional: Log level (default: INFO)
LOG_LEVEL=INFO

# Future: Stripe keys for payment processing
# STRIPE_SECRET_KEY=sk_live_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
